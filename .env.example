# Sanity CMS configuration. Copy to .env.local and fill in the token.
# Public values (exposed to the browser):
NEXT_PUBLIC_SANITY_PROJECT_ID=t1v1zdls
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Server-only editor token with write access (get it from the Sanity dashboard,
# https://sanity.io/manage → API → Tokens). Keep it secret — never commit it.
SANITY_API_TOKEN=
